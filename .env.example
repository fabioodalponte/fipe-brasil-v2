# Banco fipe-v2 (lado servidor — usado pelo plugin Vite em /api/vehicles/search).
# NÃO use prefixo VITE_ aqui: este valor não deve ir para o bundle do cliente.
FIPE_DATABASE_URL=postgresql://usuario:senha@host:5432/fipe-v2

# Modo mock no frontend (fallback). 'true' = usa dados mockados; vazio/false = API real.
VITE_USE_MOCK=
